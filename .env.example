# Onklaud 5 — Environment Configuration
# Copy this file to .env and fill in your keys
# cp .env.example .env

# === REQUIRED: OpenRouter API Key ===
# Get yours at https://openrouter.ai/keys
# Onklaud 5 uses this for Kimi K2.7 Code + GLM 5.2
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === OPTIONAL: Backup OpenRouter Key ===
# Second key for failover if primary is rate-limited
# OPENROUTER_API_KEY_BACKUP=sk-or-v1-your-backup-key-here

# === OPTIONAL: Local Model (DeepSeek V4 Pro or any compatible provider) ===
# Used for lightweight tasks when you want to save OpenRouter credits.
# Supports any OpenAI-compatible endpoint (Ollama, LM Studio, vLLM, etc.)
# LOCAL_MODEL_API_KEY=your-local-key
# LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL_NAME=deepseek-chat
